warmmaz_Mieszkania$Liczba_Mieszkan <- warmmaz_Mieszkania$Liczba_Mieszkan / warmmaz_ludnosc$Liczba_Ludnosci * 10000
set.seed(999)
test_perm_var <- function(x,y){
z <- c(x,y)
n1 <- length(x)
n2 <- length(y)
s <- var(x)/var(y)
if(s<1) s = 1/s
smp <- sapply(1:10000, sample, x=z, size=n1+n2)
stat <- vector()
for(i in 1:10000){
a <- smp[1:n1,i]
b <- smp[(n1+1):(n1+n2),i]
if(var(a)>var(b)){
stat[i] <- var(a)/var(b)
} else{
stat[i] <- var(b)/var(a)
}
}
return(sum(stat>s)/10000)
}
library(moments)
test_perm <- function(x,y,s){
z <- c(x,y)
n1 <- length(x)
n2 <- length(y)
m <- abs((s(x) - s(y)))
smp <- sapply(1:10000, sample, x=z, size = n1+n2)
stat <- vector()
for(i in 1:10000){
a <- smp[1:n1,i]
b <- smp[(n1+1):(n1+n2),i]
stat[i] <- abs(s(a)-s(b))
}
return(sum(stat > m)/10000)
}
