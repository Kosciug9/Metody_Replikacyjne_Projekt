if(s<1) s = 1/s
smp <- sapply(1:10000, sample, x=z, size=n1+n2)
stat <- vector()
for(i in 1:10000){
a <- smp[1:n1,i]
b <- smp[(n1+1):(n1+n2),i]
if(var(a)>var(b)){
stat[i] <- var(a)/var(b)
} else{
stat[i] <- var(b)/var(a)
}
}
return(sum(stat>s)/10000)
}
